{
    "expo": {
        "name": "Helium",
        "slug": "Helium",
        "version": "1.0.0",
        "orientation": "default",
        "icon": "./assets/images/icon.png",
        "scheme": "helium",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "targetDeviceFamily": "2",
            "requiresFullScreen": false
        },

        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        }
    }
}
